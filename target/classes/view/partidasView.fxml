                    </font>
                    <VBox.margin>
                        <Insets bottom="30.0" top="20.0" />
                    </VBox.margin>
                </Label>
                <Label fx:id="Iniciativa" text="Iniciativa" />
                <TextField fx:id="fieldIniciativa" prefHeight="27.0" prefWidth="212.0">
                    <VBox.margin>
                        <Insets left="10.0" right="10.0" />
                    </VBox.margin></TextField>
                <Label text="Tipo de gasto" />
                <TextField fx:id="fieldTipoGasto">
                    <VBox.margin>
                        <Insets left="10.0" right="10.0" />
                    </VBox.margin>
                </TextField>
                <Label text="Sociedad Interna" />
                <ComboBox fx:id="cmboSociedadInterna" prefHeight="27.0" prefWidth="212.0" />
                <Label text="Importe" />
                <TextField fx:id="fieldImporte">
                    <VBox.margin>
                        <Insets left="10.0" right="10.0" />
                    </VBox.margin>
                </TextField>
                <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0" spacing="10.0">
                    <children>
                        <Button fx:id="btnGuardar" mnemonicParsing="false" text="GUARDAR" textFill="#3e803e" />
                        <Button fx:id="btnCancelar" cancelButton="true" mnemonicParsing="false" text="CANCELAR" textFill="#a42f2f" />
                    </children>
