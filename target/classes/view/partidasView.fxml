<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="500.0" prefWidth="850.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.techformate.gastos.controller.vistas.partidasViewController">

    <left>
        <VBox alignment="TOP_CENTER" prefHeight="500.0" prefWidth="150.0" spacing="15.0" style="-fx-background-color: #e0e0e0;" BorderPane.alignment="CENTER">
            <children>
                <Label text="MENÚ">
                    <font>
                        <Font name="System Bold" size="16.0" />
                    </font>
                    <VBox.margin>
                        <Insets bottom="10.0" top="20.0" />
                    </VBox.margin>
                </Label>
                <Button fx:id="btnIrPartidas" maxWidth="1.7976931348623157E308" mnemonicParsing="false" text="Partidas" />
                <Button fx:id="btnIrGastos" maxWidth="1.7976931348623157E308" mnemonicParsing="false" text="Gastos" />
                <Button fx:id="btnIrFacturas" maxWidth="1.7976931348623157E308" mnemonicParsing="false" text="Facturas" />

                <VBox VBox.vgrow="ALWAYS" />

                <Button fx:id="btnVolver" maxWidth="1.7976931348623157E308" mnemonicParsing="false" text="Volver" textFill="#2f5da8">
                    <VBox.margin>
                        <Insets bottom="20.0" />
                    </VBox.margin>
                </Button>
            </children>
            <padding>
                <Insets left="15.0" right="15.0" />
            </padding>
        </VBox>
    </left>

    <center>
        <BorderPane prefHeight="370.0" prefWidth="600.0" BorderPane.alignment="CENTER">
            <center>
                <TableView fx:id="partidas" prefHeight="297.0" prefWidth="451.0" BorderPane.alignment="CENTER">
                    <columns>
                        <TableColumn fx:id="sociedadInterna" prefWidth="75.0" text="Sociedad Interna" />
                        <TableColumn fx:id="importe" prefWidth="75.0" text="Importe" />
                        <TableColumn fx:id="iniciativa" prefWidth="75.0" text="Iniciativa" />
                        <TableColumn fx:id="tipoGasto" prefWidth="75.0" text="Tipo de gasto" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>
            </center>
            <bottom>
                <HBox alignment="CENTER" prefHeight="72.0" prefWidth="600.0" spacing="20.0" BorderPane.alignment="CENTER">
                    <children>
                        <Button fx:id="btnAnadir" mnemonicParsing="false" text="Añadir" />
                        <Button fx:id="btnEditar" mnemonicParsing="false" text="Editar" />
                        <Button fx:id="btnBorrar" cancelButton="true" mnemonicParsing="false" text="Borrar" textFill="#ba2c2c" />
                  <Separator orientation="VERTICAL" prefHeight="200.0" />
                  <Button fx:id="btnExportarXML" mnemonicParsing="false" text="Exportar XML" textAlignment="CENTER" textOverrun="CENTER_ELLIPSIS" wrapText="true">
                     <font>
                        <Font size="10.0" />
                     </font>
                  </Button>
                    </children>
                </HBox>
            </bottom>
        </BorderPane>
    </center>

    <right>
        <VBox fx:id="contenedorFormulario" alignment="CENTER" prefHeight="400.0" prefWidth="233.0" spacing="10.0" BorderPane.alignment="CENTER_LEFT">
            <children>
                <Label fx:id="tituloFormulario" text="EDITAR REGISTRO" textAlignment="CENTER" underline="true">
