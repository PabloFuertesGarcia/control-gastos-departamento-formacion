<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="500.0" prefWidth="850.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.techformate.gastos.controller.vistas.FacturasViewController">

    <left>
        <VBox alignment="TOP_CENTER" prefHeight="500.0" prefWidth="150.0" spacing="15.0" style="-fx-background-color: #e0e0e0;" BorderPane.alignment="CENTER">
            <children>
                <Label text="MENU">
                    <font>
                        <Font name="System Bold" size="16.0" />
                    </font>
                    <VBox.margin>
                        <Insets bottom="10.0" top="20.0" />
                    </VBox.margin>
                </Label>
                <Button fx:id="btnIrPartidas" maxWidth="1.7976931348623157E308" mnemonicParsing="false" text="Partidas" />
                <Button fx:id="btnIrGastos" maxWidth="1.7976931348623157E308" mnemonicParsing="false" text="Gastos" />
                <Button fx:id="btnIrFacturas" maxWidth="1.7976931348623157E308" mnemonicParsing="false" text="Facturas" />

                <VBox VBox.vgrow="ALWAYS" />

                <Button fx:id="btnVolver" maxWidth="1.7976931348623157E308" mnemonicParsing="false" text="Volver" textFill="#2f5da8">
                    <VBox.margin>
                        <Insets bottom="20.0" />
                    </VBox.margin>
                </Button>
            </children>
            <padding>
                <Insets left="15.0" right="15.0" />
            </padding>
        </VBox>
    </left>

    <center>
        <BorderPane prefHeight="370.0" prefWidth="600.0" BorderPane.alignment="CENTER">
            <center>
                <TableView fx:id="facturas" prefHeight="297.0" prefWidth="451.0" BorderPane.alignment="CENTER">
                    <columns>
                        <TableColumn fx:id="colFecha" prefWidth="75.0" text="Fecha" />
                        <TableColumn fx:id="colProveedor" prefWidth="75.0" text="Proveedor" />
                        <TableColumn fx:id="colSociedadInterna" prefWidth="75.0" text="Sociedad Interna" />
                  <TableColumn fx:id="colImporte" prefWidth="75.0" text="Importe" />
                  <TableColumn fx:id="colNumFactura" prefWidth="75.0" text="Nª Factura" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>
            </center>
            <bottom>
                <HBox alignment="CENTER" prefHeight="72.0" prefWidth="600.0" spacing="20.0" BorderPane.alignment="CENTER">
                    <children>
                        <Button fx:id="btnAnadir" mnemonicParsing="false" text="Añadir" />
                        <Button fx:id="btnEditar" mnemonicParsing="false" text="Editar" />
                        <Button fx:id="btnBorrar" cancelButton="true" mnemonicParsing="false" text="Borrar" textFill="#ba2c2c" />
                    </children>
                </HBox>
            </bottom>
        </BorderPane>
    </center>

    <right>
        <VBox fx:id="contenedorFormulario" alignment="CENTER" prefHeight="400.0" prefWidth="233.0" spacing="2.0" BorderPane.alignment="CENTER_LEFT">
            <children>
                <Label fx:id="tituloFormulario" text="EDITAR REGISTRO" textAlignment="CENTER" underline="true">
                    <font>
                        <Font name="System Bold" size="14.0" />
                    </font>
                    <VBox.margin>
                        <Insets bottom="5.0" top="10.0" />
                    </VBox.margin>
                </Label>
                <Label text="Proveedor" />
                <ComboBox fx:id="cmboProveedor" prefHeight="27.0" prefWidth="212.0" />
            <Label text="Sociedad interna" />
            <ComboBox fx:id="cmboSociedadInterna" prefHeight="27.0" prefWidth="212.0" />
            <Label text="Fecha de emisión" />
            <DatePicker fx:id="dPFecha" prefWidth="212.0" />
                <Label fx:id="lblNumFactura" text="Número de Factura" />
                <TextField fx:id="fieldNumFactura" prefHeight="27.0" prefWidth="212.0">
                    <VBox.margin>
                        <Insets left="10.0" right="10.0" />
                    </VBox.margin></TextField>
                <Label text="Importe" />
                <TextField fx:id="fieldImporte">
                    <VBox.margin>
                        <Insets left="10.0" right="10.0" />
                    </VBox.margin>
                </TextField>
            <Label text="Imputaciones de la factura" />
                <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0" spacing="10.0">
                    <children>
                        <Button fx:id="btnGuardar" mnemonicParsing="false" prefHeight="54.0" prefWidth="79.0" text="GUARDAR" textFill="#3e803e" wrapText="true" />
                        <Button fx:id="btnCancelar" cancelButton="true" mnemonicParsing="false" prefHeight="54.0" prefWidth="83.0" text="CANCELAR" textFill="#a42f2f" wrapText="true" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </right>
</BorderPane>
